# Ark API key for Doubao Seedance 2.0 and Doubao Seedream image models.
# Source: https://ark.volcengine.com/region:cn-beijing/apiKey?apikey=%7B%7D
# Do not use the Volcano Speech/OpenSpeech key here.
SEEDANCE_API_KEY=your_volcano_ark_api_key
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MODEL=doubao-seedance-2-0-260128
SEEDANCE_DURATION=10
SEEDANCE_RESOLUTION=720p
SEEDANCE_RATIO=16:9
SEEDANCE_GENERATE_AUDIO=true
SEEDANCE_WATERMARK=false
SEEDANCE_RETURN_LAST_FRAME=false
SEEDANCE_CAMERA_FIXED=false
SEEDANCE_POLL_INTERVAL=5
SEEDANCE_MAX_WAIT_MINUTES=30
